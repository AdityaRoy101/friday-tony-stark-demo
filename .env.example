# LiveKit credentials.
#
# Recommended local development mode:
#   scripts\start-livekit-local.ps1
#   LIVEKIT_URL=ws://127.0.0.1:7880
#   LIVEKIT_API_KEY=devkey
#   LIVEKIT_API_SECRET=secret
#
# LiveKit Cloud mode:
#   Use values from https://cloud.livekit.io
LIVEKIT_URL=wss://your-project-xxxxx.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: set a stable room for both the desktop UI and agent testing.
FRIDAY_DEFAULT_ROOM=
FRIDAY_AGENT_NAME=friday
FRIDAY_PARTICIPANT_NAME=Friday Desktop

# Voice agent provider/model tuning.
FRIDAY_MODE=balanced
FRIDAY_ENABLE_PROVIDER_FALLBACKS=true
STT_PROVIDER=sarvam
LLM_PROVIDER=openai
TTS_PROVIDER=openai
SARVAM_STT_LANGUAGE=en-IN
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_PROMPT=Common words and names: Friday, Jarvis, LiveKit, OpenAI, Sarvam, Tony Stark, world monitor, finance monitor, dashboard, latency.
OPENAI_LLM_MODEL=gpt-4o
OPENAI_LLM_TEMPERATURE=0.35
OPENAI_LLM_MAX_TOKENS=220
GEMINI_LLM_MODEL=gemini-2.5-flash
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova
TTS_SPEED=1.15

# Low-latency turn handling. Lower values feel faster but can cut off long pauses.
FRIDAY_MAX_TOOL_STEPS=5
FRIDAY_MIN_ENDPOINTING_DELAY=-1
FRIDAY_MAX_ENDPOINTING_DELAY=0.45
FRIDAY_MIN_INTERRUPTION_DURATION=0.28
FRIDAY_MIN_INTERRUPTION_WORDS=1
FRIDAY_DEBUG_TOPIC=friday.debug

# Optional: override the visible local memory file.
FRIDAY_MEMORY_PATH=

# Groq AI API key
GROQ_API_KEY=

# Sarvam AI API key (get from https://dashboard.sarvam.ai)
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx

# Deepgram API key (get from https://console.deepgram.com)
DEEPGRAM_API_KEY=

# Google Cloud credentials (used when STT_PROVIDER = "google")
# Option 1 – path to a service-account JSON file (download from GCP Console → IAM → Service Accounts)
# Option 2 – leave blank and run: gcloud auth application-default login
# Make sure the "Cloud Speech-to-Text API" is enabled in your GCP project.
GOOGLE_APPLICATION_CREDENTIALS=

# Supabase configuration for ticketing system
SUPABASE_URL=https://your-project-id.supabase.co/rest/v1
SUPABASE_API_KEY=your-supabase-api-key

GOOGLE_API_KEY=you-google-api-key (from https://aistudio.google.com/projects)
