# Prefer the root .env for shared Friday configuration.
# Use this file only when you intentionally want the desktop UI to override root .env.

# Local LiveKit dev server
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# LiveKit Cloud example:
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=your-api-key
# LIVEKIT_API_SECRET=your-api-secret

# Optional defaults
FRIDAY_DEFAULT_ROOM=
FRIDAY_AGENT_NAME=
FRIDAY_PARTICIPANT_NAME=Friday Desktop
